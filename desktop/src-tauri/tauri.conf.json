{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MonoCycle",
  "version": "0.1.0",
  "identifier": "com.monocycle.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MonoCycle",
        "width": 1480,
        "height": 1060,
        "maxWidth": 1480,
        "minWidth": 1100,
        "minHeight": 840
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
